{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Charter Schema",
  "description": "Schema for project run configuration and limits",
  "type": "object",
  "required": ["identity", "objective"],
  "properties": {
    "identity": {
      "type": "object",
      "required": ["run_id", "project_id", "project_root", "run_name", "created_at"],
      "properties": {
        "run_id": { "type": "string" },
        "project_id": { "type": "string" },
        "project_root": { "type": "string" },
        "run_name": { "type": "string" },
        "created_at": { "type": "string" }
      }
    },
    "objective": { "type": "string" },
    "boundary": {
      "type": "object",
      "properties": {
        "allowed_directories": { "type": "array", "items": { "type": "string" } },
        "forbidden_directories": { "type": "array", "items": { "type": "string" } },
        "allowed_commands": { "type": "array", "items": { "type": "string" } },
        "max_duration_seconds": { "type": ["integer", "null"] },
        "max_cost_usd": { "type": ["number", "null"] },
        "max_tokens": { "type": ["integer", "null"] }
      }
    },
    "context_refs": {
      "type": "array",
      "items": { "type": "string" }
    },
    "updated_at": { "type": "string" }
  }
}
