# Clawd Code - 环境变量配置
# 使用说明: 复制此文件为 .env 并填入你的配置
# 安全警告: .env 文件已加入 .gitignore，切勿将真实密钥提交到版本控制

# LLM 提供商配置 (选择至少一个)
# OpenAI
LLM_PROVIDER=openai
OPENAI_API_KEY=<your-api-key>
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=

# OpenRouter (兼容 OpenAI API，支持多模型)
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-or-v1-<your-api-key>
# OPENAI_MODEL=qwen/qwen2.5-coder-32b-instruct:free
# OPENAI_BASE_URL=https://openrouter.ai/api/v1

# NVIDIA NIM (40 req/min 免费)
# LLM_PROVIDER=openai
# OPENAI_API_KEY=nvapi-<your-api-key>
# OPENAI_MODEL=nvidia/llama-3.1-405b-instruct
# OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1

# Anthropic Claude
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=<your-api-key>
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

... (现有配置) ...

# ============================================
# 优化与性能 (移植自 Project B)
# ============================================

# 启用请求优化（模拟 quota 检查、标题生成等以节省额度）
ENABLE_REQUEST_OPTIMIZATION=1

# 启用思维链解析（显示模型思考过程）
ENABLE_THINKING_PARSER=1

# 启用启发式工具解析（提高非标准格式下的工具调用成功率）
ENABLE_HEURISTIC_TOOL_PARSER=1

# 全局速率限制 (每分钟最大请求数)
PROVIDER_RATE_LIMIT=40

# 最大并发流数量
PROVIDER_MAX_CONCURRENCY=5

# Google Gemini (OpenAI 兼容模式)
# LLM_PROVIDER=google
# GOOGLE_API_KEY=<your-api-key>
# GOOGLE_MODEL=gemini-2.0-flash
# GOOGLE_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# Groq (超高速推理)
# LLM_PROVIDER=groq
# GROQ_API_KEY=<your-api-key>
# GROQ_MODEL=llama-3.3-70b-versatile

# Together AI (多种开源模型)
# LLM_PROVIDER=together
# TOGETHER_API_KEY=<your-api-key>
# TOGETHER_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo

# Mistral AI (高效开源模型)
# LLM_PROVIDER=mistral
# MISTRAL_API_KEY=<your-api-key>
# MISTRAL_MODEL=mistral-large-latest

# DeepSeek (高性价比模型)
# LLM_PROVIDER=deepseek
# DEEPSEEK_API_KEY=<your-api-key>
# DEEPSEEK_MODEL=deepseek-chat

# 工作目录 (可选，默认为当前目录)
WORK_DIR=

# 最大迭代次数 (可选，默认 10)
MAX_ITERATIONS=10

# 命令超时 (秒，可选，默认 3000 即 50 分钟，ClawGod 标准)
COMMAND_TIMEOUT=3000

# 最大输出长度 (可选，默认 50000)
MAX_OUTPUT_LENGTH=50000

# ============================================
# 高级配置 (可选)
# ============================================

# API 路径后缀 (默认 /v1/chat/completions)
API_PATH_SUFFIX=/v1/chat/completions

# LLM 调用最大 Token 数 (默认 4096)
MAX_TOKENS=4096

# 温度参数 (默认 0.7)
TEMPERATURE=0.7

# 请求超时时间 (秒，默认 3000 即 50 分钟，ClawGod 标准)
TIMEOUT=3000

# 最大重试次数 (默认 3)
MAX_RETRIES=3

# 上下文最大 Token 数 (默认 8000)
MAX_CONTEXT_TOKENS=8000

# 上下文压缩阈值 (0.0-1.0，默认 0.8)
COMPRESSION_THRESHOLD=0.8

# 最大输出 Token 数 (-1 表示自动计算，默认 -1)
MAX_OUTPUT_TOKENS=-1

# 上下文窗口大小 (默认 128000)
CONTEXT_WINDOW=128000

# ============================================
# 服务器配置
# ============================================

# Agent Server 认证 Token (留空则自动生成随机 token)
AGENT_SERVER_TOKEN=

# Agent Server 端口 (默认 8765)
AGENT_SERVER_PORT=8765

# Agent Server 主机 (默认 127.0.0.1)
AGENT_SERVER_HOST=127.0.0.1

# 健康检查端口 (默认 8765，与 Agent Server 一致)
HEALTH_CHECK_PORT=8765

# ============================================
# ClawGod 风格隐私保护 (v2 整合)
# ============================================

# 禁用遥测和非必要网络流量 (ClawGod 标准，默认启用)
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1

# 禁用安装检查 (ClawGod 标准，默认启用)
DISABLE_INSTALLATION_CHECKS=1

# API 超时 (毫秒，默认 3000000 即 50 分钟，ClawGod 标准)
API_TIMEOUT_MS=3000000

# ============================================
# 日志配置
# ============================================

# 启用文件日志 (1/true/yes 启用，默认禁用)
ENABLE_FILE_LOGGING=0

# 日志级别 (DEBUG | INFO | WARN | ERROR，默认 INFO)
LOG_LEVEL=INFO

# ============================================
# 项目级数据目录
# ============================================

# Clawd Code 数据存储目录 (默认: 当前工作目录/.clawd)
# 当用户在某个项目目录下运行 clawd 命令时，会自动在该目录下创建 .clawd/ 文件夹
# 用于存储会话记录、记忆、数据库、缓存等资产
# 如需自定义路径，可取消下面注释并设置路径
# CLAWD_DIR=/path/to/custom/clawd/data/directory
